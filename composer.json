{
    "name": "rebing/graphql-laravel",
    "description": "Laravel wrapper for PHP GraphQL",
    "keywords": ["framework", "laravel", "graphql", "react"],
    "authors": [
        {
            "name": "Rebing OÜ",
            "homepage": "http://www.rebing.ee",
            "role": "Company"
        },
        {
            "name": "Mikk Mihkel Nurges",
            "email": "mikk.nurges@rebing.ee",
            "role": "Developer"
        },
        {
            "name": "Folklore",
            "email": "info@atelierfolklore.ca",
            "homepage": "http://atelierfolklore.ca"
        },
        {
            "name": "David Mongeau-Petitpas",
            "email": "dmp@atelierfolklore.ca",
            "homepage": "http://mongo.ca",
            "role": "Developer"
        },
        {
            "name": "Markus Podar",
            "email": "markus@fischer.name",
            "role": "Developer",
            "homepage": "https://github.com/mfn"
        }
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laragraph/utils": "^2.0.1",
        "thecodingmachine/safe": "^3.0",
        "webonyx/graphql-php": "^15.31.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.8.5|^8.0",
        "ext-pdo_sqlite": "*",
        "eliashaeussler/deep-closure-comparator": "^1.2",
        "fakerphp/faker": "^1.24",
        "laravel/framework": "^12.0|^13.0",
        "mockery/mockery": "^1.6.10",
        "open-telemetry/sdk": "^1.13",
        "open-telemetry/sem-conv": "^1.38",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.5.3|^12.0.1|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Rebing\\GraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rebing\\GraphQL\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "composer install --working-dir=tools/phpstan --quiet && tools/phpstan/vendor/bin/phpstan analyse --memory-limit=512M --error-format=raw",
        "phpstan-baseline": "composer install --working-dir=tools/phpstan --quiet && tools/phpstan/vendor/bin/phpstan analyse --memory-limit=512M --generate-baseline",
        "phpstan-update": "composer update --working-dir=tools/phpstan",
        "cs-update": "composer update --working-dir=tools/cs-fixer",
        "cs-lint": "composer install --working-dir=tools/cs-fixer --quiet && tools/cs-fixer/vendor/bin/php-cs-fixer fix --diff --dry-run",
        "cs-fix": "composer install --working-dir=tools/cs-fixer --quiet && tools/cs-fixer/vendor/bin/php-cs-fixer fix --diff",
        "tests": "LOG_DEPRECATIONS_CHANNEL=errorlog paratest",
        "tests-coverage": "LOG_DEPRECATIONS_CHANNEL=errorlog paratest --coverage-clover=coverage.xml",
        "bc-update": "composer update --working-dir=tools/bc-check",
        "bc-check": "composer install --working-dir=tools/bc-check --quiet && tools/bc-check/vendor/bin/roave-backward-compatibility-check",
        "bc-baseline": "composer install --working-dir=tools/bc-check --quiet && php bin/update-bc-baseline.php --strip-baseline && tools/bc-check/vendor/bin/roave-backward-compatibility-check 2>&1 | php bin/update-bc-baseline.php"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "10.x-dev"
        },
        "laravel": {
            "providers": [
                "Rebing\\GraphQL\\GraphQLServiceProvider"
            ],
            "aliases": {
                "GraphQL": "Rebing\\GraphQL\\Support\\Facades\\GraphQL"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false,
            "tbachert/spi": false
        }
    },
    "suggest": {
        "mll-lab/laravel-graphiql": "Easily integrate GraphiQL into your Laravel projects.",
        "open-telemetry/api": "Required for the OpenTelemetryTracingDriver (^1.0).",
        "rebing/graphql-laravel-select-fields": "Optimizes Eloquent queries by analysing requested GraphQL fields to build minimal SELECT and eager-load only needed relations."
    }
}
